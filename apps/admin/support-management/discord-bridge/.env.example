# FounderFirst Discord bridge — environment template.
# Copy to .env, fill in real values. .env is gitignored — never commit secrets.

DISCORD_BOT_TOKEN=paste-bot-token-here
DISCORD_SUPPORT_CHANNEL_ID=paste-channel-id-here
DIFY_API_KEY=app-paste-key-here

# Dify API base URL. On Mac with Docker Desktop, host.docker.internal reaches
# Dify's nginx on port 80. On Linux (Lightsail later) the override would be
# http://<dify-host>:<port>/v1 — adjust at deploy time.
DIFY_BASE_URL=http://host.docker.internal/v1

# Supabase — for polling admin replies. Service-role bypasses RLS; never
# expose to the browser or commit it.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste-service-role-key-here

# Poll interval in seconds for admin reply pickup.
ADMIN_POLL_INTERVAL=3
