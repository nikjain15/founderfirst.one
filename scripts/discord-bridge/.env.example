# Copy to .env on the Lightsail VM. Never commit .env.

WORKER_BASE_URL=https://bubble.founderfirst.one
BRIDGE_SECRET=paste-the-value-from-wrangler-secret-put-DISCORD_BRIDGE_SECRET

DISCORD_BOT_TOKEN=paste-from-discord-developer-portal
