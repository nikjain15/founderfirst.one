---
import "@ff/design-system/tokens.css";
import "@ff/design-system/components/reset.css";
import "@ff/design-system/components/typography.css";
import type { Page } from "@ff/content";
import { buildJsonLd } from "../lib/seo";

interface Props { page: Page }
const { page } = Astro.props;
const site = "https://founderfirst.one";
const jsonLd = buildJsonLd(page, site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={page.seo.description} />
    <link rel="canonical" href={page.seo.canonical ?? site + page.slug} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={page.seo.title} />
    <meta property="og:description" content={page.seo.description} />
    <meta property="og:url" content={site + page.slug} />
    {page.seo.ogImage && <meta property="og:image" content={page.seo.ogImage} />}
    <title>{page.seo.title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={jsonLd} is:inline />
    <style is:global>
      body { background: var(--paper); color: var(--ink); font-family: var(--sans); -webkit-font-smoothing: antialiased; }
      .wrap { width: 100%; max-width: var(--page-max); margin-inline: auto; padding-inline: var(--page-pad-x); }
      section { padding-block: var(--section-y); }
      a { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
