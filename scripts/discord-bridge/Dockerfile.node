# TypeScript bridge image (discord.js + tsx). Swap fly.toml's Dockerfile to this
# at cutover time. The Python Dockerfile stays the default until then.
FROM node:22-slim

WORKDIR /app

COPY package.json ./
RUN npm install --no-audit --no-fund

COPY bridge.ts tsconfig.json ./

CMD ["npx", "tsx", "bridge.ts"]
