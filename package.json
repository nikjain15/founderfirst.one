{
  "name": "founderfirst-web",
  "private": true,
  "version": "0.0.0",
  "description": "FounderFirst monorepo — marketing site (apps/web, Astro), admin SPA, shared design system, and vendored Penny demo.",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:web": "pnpm --filter @ff/web dev",
    "build:web": "pnpm --filter @ff/web build",
    "check:css": "tsx scripts/check-css-imports.ts",
    "check:app-strings": "tsx scripts/check-app-strings.ts",
    "check:tenant": "tsx scripts/check-tenant-predicate.ts",
    "check:inference": "tsx packages/inference/test/parity.ts",
    "check:judge": "tsx packages/inference/test/judge.ts",
    "test:chat-latency": "tsx packages/inference/test/chat-latency.ts",
    "check:vendor": "tsx scripts/check-inference-vendor.ts",
    "seed:kernel": "tsx scripts/seed-kernel.ts",
    "check:kernel-seed": "tsx scripts/seed-kernel.ts --check",
    "seed:tax": "tsx scripts/seed-tax.ts",
    "check:tax-seed": "tsx scripts/seed-tax.ts --check",
    "check:law-literals": "tsx scripts/check-law-literals.ts",
    "check:kernel-hardcodes": "tsx scripts/check-kernel-hardcodes.ts",
    "vendor:inference": "tsx scripts/vendor-inference.ts",
    "build": "tsx scripts/check-css-imports.ts && tsx scripts/check-tenant-predicate.ts && tsx scripts/check-inference-vendor.ts && tsx packages/inference/test/judge.ts && tsx scripts/build-all.ts",
    "vendor:demo": "tsx scripts/vendor-demo.ts",
    "test:responsive": "pnpm build && node tools/responsive-ci/run.mjs",
    "test:responsive:only": "node tools/responsive-ci/run.mjs"
  },
  "devDependencies": {
    "playwright": "^1.45.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
