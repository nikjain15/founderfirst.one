{
  "name": "penny-demo",
  "version": "5.0.0",
  "private": true,
  "description": "Browser-based interactive demo of Penny — an AI bookkeeper for US small business owners.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bash scripts/check-tokens.sh --all && vite build",
    "preview": "vite preview --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:tokens": "bash scripts/check-tokens.sh --all",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "deploy": "bash scripts/deploy.sh",
    "deploy:prompts": "bash scripts/deploy-prompts.sh"
  },
  "dependencies": {
    "posthog-js": "^1.371.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.17"
  }
}
