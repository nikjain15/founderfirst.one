---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PennyGlance from "../../components/PennyGlance.astro";
import PennySafe from "../../components/PennySafe.astro";
import { getBlogPosts } from "../../lib/blog";
import type { Page } from "@ff/content";

const posts = await getBlogPosts();

const page: Page = {
  slug: "/blog",
  surface: "blog",
  seo: {
    title: "Blog — Bookkeeping, minus the busywork — FounderFirst",
    description:
      "Guides and ideas on autonomous bookkeeping, clean books, and running a business without the back-office grind.",
    keyFacts: [],
  },
  sections: [],
};
const sorted = [...posts].sort((a, b) => (a.date < b.date ? 1 : -1));
const fmt = (iso: string) => new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---
<Base page={page}>
  <Nav />
  <section class="blog-hero">
    <div class="wrap">
      <p class="eyebrow brand">Blog</p>
      <h1>Bookkeeping, minus the busywork.</h1>
      <p class="lede">Guides and ideas on autonomous bookkeeping, clean books, and running a business without the back-office grind.</p>
    </div>
  </section>

  <section class="blog-list">
    <div class="wrap">
      <div class="post-list">
        {sorted.map((post) => (
          <a class="post-row" href={`/blog/${post.slug}/`}>
            <div class="row-visual">{post.hero === "safe" ? <PennySafe /> : <PennyGlance />}</div>
            <div class="row-copy">
              <div class="meta">{post.tag} · {fmt(post.date)} · {post.readMins} min read</div>
              <h2>{post.title}</h2>
              <p>{post.description}</p>
              <span class="more">Read article →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  <Footer />
</Base>
<style>
  .eyebrow { font-size: var(--fs-eyebrow); letter-spacing: var(--ls-eyebrow); text-transform: uppercase; color: var(--ink-4); font-weight: var(--fw-semibold); }
  .eyebrow.brand { color: var(--brand); margin-bottom: var(--space-3); }
  .blog-hero { padding-bottom: var(--space-6); }
  h1 { font-size: var(--fs-display-1); line-height: 1.06; letter-spacing: var(--ls-tight); margin-bottom: var(--space-4); }
  .lede { font-size: var(--fs-body); color: var(--ink-3); line-height: 1.6; max-width: 600px; }
  .meta { font-size: var(--fs-eyebrow); text-transform: uppercase; letter-spacing: var(--ls-eyebrow); color: var(--ink-4); font-weight: var(--fw-semibold); }
  .more { color: var(--brand); font-weight: var(--fw-medium); font-size: var(--fs-data-row); }

  /* One consistent card format for every post: visual + copy, side by side. */
  .post-list { display: grid; gap: var(--space-6); }
  .post-row { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 0; border: var(--bw-hair) solid var(--line); border-radius: var(--r-card-emph); overflow: hidden; background: var(--white); transition: box-shadow var(--dur-base) var(--ease-out); }
  .post-row:hover { box-shadow: var(--shadow-float); }
  .row-visual { background: var(--brand-tint); display: grid; place-items: center; padding: clamp(24px, 4vw, 48px); border-right: var(--bw-hair) solid var(--line); }
  .row-copy { padding: clamp(24px, 4vw, 44px); display: flex; flex-direction: column; gap: var(--space-3); justify-content: center; }
  .row-copy h2 { font-family: var(--font-display); font-size: clamp(22px, 2.6vw, 28px); line-height: 1.2; }
  .row-copy p { font-size: var(--fs-data-row); color: var(--ink-3); line-height: 1.6; }

  @media (max-width: 700px) {
    .post-row { grid-template-columns: 1fr; }
    .row-visual { border-right: 0; border-bottom: var(--bw-hair) solid var(--line); }
  }
</style>
