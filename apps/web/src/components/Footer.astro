<footer>
  <div class="wrap foot-inner">
    <span class="logo"><span class="ff">FF</span> FounderFirst</span>
    <nav class="foot-links" aria-label="Footer">
      <a href="/">Home</a>
      <a href="/#product">Product</a>
      <a href="#faq">FAQ</a>
      <a href="#waitlist">Early access</a>
      <a href="/compare/">Compare</a>
      <a href="/blog/">Blog</a>
      <a href="https://discord.gg/DGJdd6AEjH" target="_blank" rel="noopener noreferrer">Chat on Discord</a>
    </nav>
    <span class="copy">© 2026 FounderFirst. All rights reserved.</span>
  </div>
</footer>
<style>
  footer { border-top: 1px solid var(--line); padding-block: var(--space-10); }
  .foot-inner { display: flex; flex-direction: column; gap: var(--space-5); }
  .logo { display: flex; align-items: center; gap: var(--space-2); font-weight: var(--fw-bold); }
  .ff { display: grid; place-items: center; width: 24px; height: 24px; border-radius: 6px; background: var(--ink); color: var(--white); font-size: var(--fs-tiny); font-weight: var(--fw-bold); }
  .foot-links { display: flex; flex-wrap: wrap; gap: var(--space-3) var(--space-5); font-size: var(--fs-data-row); color: var(--ink-3); }
  .foot-links a { min-height: var(--tap-min); display: inline-flex; align-items: center; }
  .foot-links a:hover { color: var(--brand); }
  .copy { font-size: var(--fs-eyebrow); color: var(--ink-4); }
  @media (min-width: 768px) {
    .foot-inner { flex-direction: row; align-items: center; justify-content: space-between; flex-wrap: wrap; }
    .foot-links { order: 3; flex-basis: 100%; border-top: 1px solid var(--line-2); padding-top: var(--space-4); }
  }
</style>
