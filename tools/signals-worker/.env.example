# Signals worker config. Copy to .env and fill in. NEVER commit the real .env.

# --- Supabase (service role — server-side only, full access) ---
SUPABASE_URL=https://ejqsfzggyfsjzrcevlnq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Ollama (local on the VM) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# qwen2.5:7b won the scoring eval (cleaner separation; see eval.mjs). Needs ~5GB
# RAM. On a low-RAM box (e.g. 4GiB), fall back to gemma2:2b (also 100% accurate
# in the eval, just tighter margins).
OLLAMA_SCORE_MODEL=qwen2.5:7b-instruct-q4_K_M

# --- Managed drafting (Anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Scoring thresholds / cadence ---
REL_THRESHOLD=0.55          # min relevance to promote
REL_FLOOR=0.30              # below this AND no keyword hit -> archive before LLM
INTENT_THRESHOLD=55         # min intent (0-100) to promote
BATCH=10                    # items per cycle
POLL_INTERVAL_SECONDS=60    # idle pause between cycles
