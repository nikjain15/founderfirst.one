# Copy to .env.local for local dev. .env.local is gitignored.
# In CI (.github/workflows/pages.yml) these come from repo vars + secrets.

VITE_SUPABASE_URL=https://ejqsfzggyfsjzrcevlnq.supabase.co
VITE_SUPABASE_ANON_KEY=paste-the-supabase-anon-key

# Optional. If set, only this email can sign in. Leave empty for any email
# (useful while iterating locally).
VITE_ADMIN_EMAIL=

# Dev-only auto-login (apps/admin/src/lib/devAuth.ts). When BOTH are set in a
# `vite dev` build, the admin auto-signs-in with these creds — so the auth-gated
# UI can be driven in the preview / by an automated agent without a magic link.
# Use a THROWAWAY test admin that's in the `admins` allow-list, never a real
# account. Stripped from prod builds (only active in DEV or a VITE_E2E=1 build).
VITE_DEV_ADMIN_EMAIL=
VITE_DEV_ADMIN_PASSWORD=
