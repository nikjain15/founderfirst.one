{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": []
  },
  "comment": "driver.ts dynamically imports @supabase/supabase-js at runtime only (sandbox live runs); it is not a build/CI dependency.",
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
